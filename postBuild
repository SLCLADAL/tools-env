#!/bin/bash
set -e

# ============================================================
#  postBuild — tools-env Binder build script
#  Runs ONCE at image build time, not at session startup.
#  Order matters: Java → R Java config → udpipe models → warm-up
# ============================================================

# ── 1. Configure Java for R (required by topicmodels) ───────
# Java is installed via apt.txt (default-jre, default-jdk).
# The -e flag writes Java config to ~/.R/Makevars (user-writable)
# rather than /opt/R/.../etc/Makeconf which is read-only for jovyan.
echo "=== Configuring Java for R (user-level) ==="
mkdir -p "${HOME}/.R"
R CMD javareconf -e 2>&1 || echo "WARN: javareconf returned non-zero — continuing"
echo "=== Java configuration complete ==="

# ── 2. Set up Jupyter config directory ──────────────────────
mkdir -p ~/.jupyter
echo "=== Jupyter config directory ready ==="

# ── 3. Download udpipe language models ──────────────────────
mkdir -p "${HOME}/udpipe-models"

cat > /tmp/download_models.R << 'EOF'
library(udpipe)
model_dir <- file.path(Sys.getenv("HOME"), "udpipe-models")
models <- c(
  "arabic-padt",
  "chinese-gsd", "chinese-gsdsimp",
  "dutch-alpino", "dutch-lassysmall",
  "english-ewt", "english-gum", "english-lines", "english-partut",
  "french-gsd", "french-partut", "french-sequoia", "french-spoken",
  "german-gsd", "german-hdt",
  "italian-isdt", "italian-partut", "italian-postwita",
  "italian-twittiro", "italian-vit",
  "japanese-gsd",
  "portuguese-bosque", "portuguese-gsd",
  "russian-gsd", "russian-syntagrus", "russian-taiga",
  "spanish-ancora", "spanish-gsd"
)
for (lang in models) {
  existing <- list.files(model_dir, pattern = paste0("^", lang, ".*\\.udpipe$"))
  if (length(existing) > 0) {
    cat("  [skip]", lang, "\n")
    next
  }
  cat("  [download]", lang, "...")
  tryCatch({
    dl <- udpipe_download_model(language = lang, model_dir = model_dir)
    if (dl$download_failed) cat("FAILED\n") else cat("OK\n")
  }, error = function(e) cat("ERROR:", conditionMessage(e), "\n"))
}
cat("Done. Models:", length(list.files(model_dir, pattern = "\\.udpipe$")), "\n")
EOF

Rscript --vanilla /tmp/download_models.R
echo "=== udpipe model download complete ==="

# ── 4. Pre-warm heavy R packages ────────────────────────────
# Forces R to load and bytecode-compile the slowest packages
# at image build time rather than at the first user session.
# This typically saves 5-15 seconds off startup time per tool.
echo "=== Pre-warming R packages ==="

Rscript --vanilla -e "
  pkgs <- c(
    # Topic modelling (heaviest — Java-backed)
    'topicmodels',
    'seededlda',
    'tidytext',
    'SnowballC',
    # NLP / corpus
    'quanteda',
    'quanteda.textstats',
    'quanteda.textplots',
    'udpipe',
    # Networks
    'visNetwork',
    # Sentiment
    'stringi',
    # General
    'shiny',
    'DT',
    'ggplot2',
    'dplyr',
    'writexl'
  )
  for (pkg in pkgs) {
    cat('  Loading', pkg, '...')
    tryCatch({
      library(pkg, character.only = TRUE)
      cat('OK\n')
    }, error = function(e) {
      cat('WARN:', conditionMessage(e), '\n')
    })
  }
  cat('Pre-warming complete.\n')
" || echo "WARN: package pre-warming exited non-zero — continuing"

echo "=== Package pre-warming complete ==="

# ── 5. Pre-warm textstem (lazy-loaded in WordWebber) ────────
# textstem pulls in koRpus/sylly — loading it once here caches
# its internal lexicon data so the first user click is instant.
echo "=== Pre-warming textstem ==="

Rscript --vanilla -e "
  tryCatch({
    library(textstem)
    # Trigger the lexicon load by lemmatising a test word
    textstem::lemmatize_words('running')
    cat('textstem pre-warmed OK\n')
  }, error = function(e) {
    cat('textstem WARN:', conditionMessage(e), '\n')
  })
" || echo "WARN: textstem pre-warming exited non-zero — continuing"

echo "=== textstem pre-warming complete ==="
echo "=== postBuild finished ==="
