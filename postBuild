#!/bin/bash
set -e

echo "=== Downloading udpipe language models ==="

mkdir -p ${HOME}/udpipe-models

cat > /tmp/download_models.R << 'EOF'
library(udpipe)
model_dir <- file.path(Sys.getenv("HOME"), "udpipe-models")
models <- c(
  "arabic-padt",
  "chinese-gsd", "chinese-gsdsimp",
  "dutch-alpino", "dutch-lassysmall",
  "english-ewt", "english-gum", "english-lines", "english-partut",
  "french-gsd", "french-partut", "french-sequoia", "french-spoken",
  "german-gsd", "german-hdt",
  "italian-isdt", "italian-partut", "italian-postwita",
  "italian-twittiro", "italian-vit",
  "japanese-gsd",
  "portuguese-bosque", "portuguese-br", "portuguese-gsd",
  "russian-gsd", "russian-syntagrus", "russian-taiga",
  "spanish-ancora", "spanish-gsd"
)
for (lang in models) {
  existing <- list.files(model_dir, pattern = paste0("^", lang, ".*\\.udpipe$"))
  if (length(existing) > 0) {
    cat("  [skip]", lang, "\n")
    next
  }
  cat("  [download]", lang, "...")
  tryCatch({
    dl <- udpipe_download_model(language = lang, model_dir = model_dir)
    if (dl$download_failed) cat("FAILED\n") else cat("OK\n")
  }, error = function(e) cat("ERROR:", conditionMessage(e), "\n"))
}
cat("Done. Models:", length(list.files(model_dir, pattern = "\\.udpipe$")), "\n")
EOF

Rscript --vanilla /tmp/download_models.R

echo "=== udpipe model download complete ==="
